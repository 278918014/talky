<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/talky_page_bg"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_back_button_light"
            android:contentDescription="返回"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/title_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toStartOf="@id/date_filter_card"
            app:layout_constraintStart_toEndOf="@id/back_button"
            app:layout_constraintTop_toTopOf="@id/back_button">

            <TextView
                android:id="@+id/page_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史练习"
                android:textColor="@color/talky_text"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="复盘每一次口播表现"
                android:textColor="@color/talky_subtext"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/date_filter_card"
            android:layout_width="64dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_history_filter_active"
            android:gravity="center"
            android:text="日期"
            android:textColor="@color/talky_surface"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/back_button" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/summary_panel"
        android:layout_width="match_parent"
        android:layout_height="118dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_history_summary"
        android:padding="18dp">

        <TextView
            android:id="@+id/summary_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最近 30 天"
            android:textColor="@color/talky_primary_soft"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/summary_total"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0 条练习"
            android:textColor="@color/talky_surface"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/today_metric"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/summary_range" />

        <TextView
            android:id="@+id/summary_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:text="累计 0 分钟，保持稳定输出"
            android:textColor="@color/talky_primary_soft"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/summary_total" />

        <LinearLayout
            android:id="@+id/today_metric"
            android:layout_width="48dp"
            android:layout_height="58dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_history_metric"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/week_metric"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日"
                android:textColor="@color/talky_subtext"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/today_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/talky_recording_dark"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/week_metric"
            android:layout_width="48dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_history_metric"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本周"
                android:textColor="@color/talky_subtext"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/week_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/talky_recording_dark"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/date_filter_text"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_history_filter_active"
                android:ellipsize="end"
                android:gravity="center"
                android:maxWidth="138dp"
                android:paddingHorizontal="20dp"
                android:singleLine="true"
                android:text="最近录制"
                android:textColor="@color/talky_surface"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/week_filter"
                style="@style/TalkyMiniChip"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_history_filter"
                android:gravity="center"
                android:text="本周" />

            <TextView
                android:id="@+id/month_filter"
                style="@style/TalkyMiniChip"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_history_filter"
                android:gravity="center"
                android:text="本月" />

            <TextView
                android:id="@+id/longest_filter"
                style="@style/TalkyMiniChip"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_history_filter"
                android:gravity="center"
                android:text="最长" />

            <TextView
                android:id="@+id/clear_filter"
                style="@style/TalkyMiniChip"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_history_filter"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minWidth="76dp"
                android:text="删除当前"
                android:textColor="@color/talky_primary_deep"
                android:visibility="gone" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:alpha="0.4"
            android:contentDescription="空"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/talky_subtext" />

        <TextView
            style="@style/TalkyBody"
            android:layout_marginTop="16dp"
            android:text="还没有练习记录"
            android:textColor="@color/talky_subtext" />

        <TextView
            style="@style/TalkyBody.Small"
            android:layout_marginTop="6dp"
            android:text="去首页开始一段口播练习吧" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp" />
</LinearLayout>
