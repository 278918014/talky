<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/talky_page_bg">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_back_button_light"
                android:contentDescription="返回"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/page_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="录制中"
                android:textColor="@color/talky_text"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/rec_indicator"
                style="@style/TalkyRecChip"
                android:drawableStart="@android:drawable/presence_online"
                android:drawablePadding="6dp"
                android:text="REC 00:00" />

            <TextView
                android:id="@+id/switch_camera_button"
                style="@style/TalkyHeaderChip"
                android:layout_marginStart="8dp"
                android:text="切镜头" />

            <TextView
                android:id="@+id/settings_button"
                style="@style/TalkyHeaderChip.Light"
                android:layout_marginStart="8dp"
                android:text="设置" />
        </LinearLayout>
    </LinearLayout>

    <!-- 摄像头预览区域 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/camera_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintDimensionRatio="9:16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintVertical_bias="0"
        app:strokeColor="@color/talky_border"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_recording_surface">

            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 无摄像头时的占位 -->
            <LinearLayout
                android:id="@+id/camera_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/talky_video_placeholder"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.5"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="摄像头" />

                <TextView
                    style="@style/TalkyBody.Small"
                    android:layout_marginTop="12dp"
                    android:text="摄像头不可用"
                    android:textColor="@color/talky_surface" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/camera_card"
        app:layout_constraintVertical_bias="1">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pause_button"
            style="@style/Widget.Talky.SecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="开始" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop_button"
            style="@style/Widget.Talky.DangerButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="停止并保存" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
