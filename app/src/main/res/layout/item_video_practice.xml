<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/talky_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/talky_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/thumbnail"
            android:layout_width="88dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_video_thumb"
            android:clipToOutline="true"
            android:contentDescription="视频封面"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/title"
                style="@style/TalkySectionTitle"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="16:13 录制"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/meta"
                style="@style/TalkyBody.Small"
                android:layout_marginTop="6dp"
                android:text="6秒 · 720P" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
